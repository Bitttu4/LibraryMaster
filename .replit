modules = ["cpp"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LibrarySystem"

[[workflows.workflow]]
name = "LibrarySystem"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "make && ./library_system"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "make && ./library_system"]

[[ports]]
localPort = 5000
externalPort = 80
